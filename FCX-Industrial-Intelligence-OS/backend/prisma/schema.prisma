generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  COMPRESSOR
  RACK
  COLD_ROOM
  EVAPORATOR
  CONDENSER
  PANEL
  SENSOR
  PUMP
  FAN
  OTHER
}

enum AssetCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  ALARM
}

enum RegistryStatus {
  ACTIVE
  INACTIVE
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  ALERT
  INACTIVE
}

enum AlarmSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlarmStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  CLOSED
}

enum UserRole {
  ADMIN
  MANAGER
  ENGINEER
  TECHNICIAN
  VIEWER
  MASTER_ADMIN
  FCX_ADMIN
  SUPERVISOR
  CLIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model Asset {
  id           String           @id @default(uuid())
  companyId    String?          @map("company_id")
  company      Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  siteId       String?          @map("site_id")
  site         Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  nome         String
  tipo         AssetType
  fabricante   String?
  modelo       String?
  serialNumber String?          @map("serial_number")
  brand        String?
  location     String?
  unidade      String
  criticidade  AssetCriticality @default(MEDIUM)
  status       AssetStatus      @default(ONLINE)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  telemetry    Telemetry[]
  telemetryRaw TelemetryRaw[]
  telemetryProcessed TelemetryProcessed[]
  alarms       Alarm[]
  alarmEvents  AlarmEvent[]
  workOrders   WorkOrder[]
  sensors      Sensor[]
  devices      Device[]

  @@index([companyId, status])
  @@index([siteId, status])
  @@map("assets")
}

model Client {
  id        String         @id @default(uuid())
  name      String
  cnpj      String         @unique
  email     String
  phone     String
  address   String
  city      String
  state     String
  status    RegistryStatus @default(ACTIVE)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  sites     Site[]

  @@map("clients")
}

model Company {
  id           String         @id @default(uuid())
  name         String
  document     String         @unique
  contactName  String         @map("contact_name")
  contactEmail String         @map("contact_email")
  contactPhone String         @map("contact_phone")
  status       RegistryStatus @default(ACTIVE)
  createdAt    DateTime       @default(now()) @map("created_at")
  sites        Site[]
  assets       Asset[]
  telemetry    Telemetry[]
  alarms       Alarm[]
  workOrders   WorkOrder[]
  users        User[]

  @@map("companies")
}

model Site {
  id        String         @id @default(uuid())
  companyId String?        @map("company_id")
  company   Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  clientId  String?        @map("client_id")
  client    Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  name      String
  address   String
  city      String
  state     String
  status    RegistryStatus @default(ACTIVE)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  assets    Asset[]
  gateways  Gateway[]

  @@index([companyId, status])
  @@index([clientId, status])
  @@map("sites")
}

model Device {
  id           String       @id @default(uuid())
  assetId      String?      @map("asset_id")
  asset        Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  name         String
  serialNumber String       @unique @map("serial_number")
  deviceType   String       @map("device_type")
  protocol     String
  status       DeviceStatus @default(ONLINE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([assetId, status])
  @@map("devices")
}

model Sensor {
  id        String       @id @default(uuid())
  assetId   String       @map("asset_id")
  asset     Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name      String
  type      String
  unit      String
  protocol  String
  mqttTopic String?      @map("mqtt_topic")
  status    DeviceStatus @default(ONLINE)
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([assetId, status])
  @@map("sensors")
}

model Gateway {
  id        String       @id @default(uuid())
  siteId    String       @map("site_id")
  site      Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  model     String
  ipAddress String       @map("ip_address")
  protocol  String
  status    DeviceStatus @default(ONLINE)
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([siteId, status])
  @@map("gateways")
}

model TelemetryRaw {
  id          String   @id @default(uuid())
  assetId     String?  @map("asset_id")
  asset       Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  source      String
  protocol    String
  topic       String?
  payload     Json
  receivedAt  DateTime @default(now()) @map("received_at")

  @@index([assetId, receivedAt])
  @@index([source, protocol, receivedAt])
  @@map("telemetry_raw")
}

model TelemetryProcessed {
  id              String   @id @default(uuid())
  rawId           String?  @map("raw_id")
  assetId         String   @map("asset_id")
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  source          String
  timestamp       DateTime @default(now())
  temperatura     Float?
  vibracao        Float?
  corrente        Float?
  tensao          Float?
  potencia        Float?
  pressao         Float?
  pressaoSuccao   Float?   @map("pressao_succao")
  pressaoDescarga Float?   @map("pressao_descarga")
  umidade         Float?
  quality         String   @default("GOOD")

  @@index([assetId, timestamp])
  @@index([source, timestamp])
  @@map("telemetry_processed")
}

model AlarmEvent {
  id          String   @id @default(uuid())
  assetId     String   @map("asset_id")
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  source      String
  severidade  String
  titulo      String
  descricao   String?
  metric      String?
  value       Float?
  threshold   Float?
  timestamp   DateTime @default(now())
  status      String   @default("ACTIVE")

  @@index([assetId, status, timestamp])
  @@index([source, timestamp])
  @@map("alarm_events")
}

model Telemetry {
  id               String   @id @default(uuid())
  companyId        String?  @map("company_id")
  company          Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  clientId         String?  @map("client_id")
  siteId           String?  @map("site_id")
  deviceId         String?  @map("device_id")
  assetId          String   @map("asset_id")
  asset            Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  timestamp        DateTime @default(now())
  temperatura      Float
  vibracao         Float
  corrente         Float
  tensao           Float
  potencia         Float
  pressaoSuccao    Float    @map("pressao_succao")
  pressaoDescarga  Float    @map("pressao_descarga")

  @@index([companyId, timestamp])
  @@index([clientId, timestamp])
  @@index([siteId, timestamp])
  @@index([deviceId, timestamp])
  @@index([assetId, timestamp])
  @@map("telemetry")
}

model Alarm {
  id          String        @id @default(uuid())
  companyId   String?       @map("company_id")
  company     Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assetId     String        @map("asset_id")
  asset       Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  severidade  AlarmSeverity
  titulo      String
  descricao   String?
  timestamp   DateTime      @default(now())
  status      AlarmStatus   @default(ACTIVE)

  @@index([companyId, status, timestamp])
  @@index([assetId, status, timestamp])
  @@map("alarms")
}

model WorkOrder {
  id             String            @id @default(uuid())
  companyId      String?           @map("company_id")
  company        Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  numeroOs       String            @unique @map("numero_os")
  assetId        String            @map("asset_id")
  ativo          Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tecnico        String
  prioridade     WorkOrderPriority @default(MEDIUM)
  status         WorkOrderStatus   @default(OPEN)
  descricao      String
  dataAbertura   DateTime          @default(now()) @map("data_abertura")
  dataFechamento DateTime?         @map("data_fechamento")

  @@index([companyId, status, dataAbertura])
  @@index([assetId, status, dataAbertura])
  @@map("work_orders")
}

model User {
  id             String               @id @default(uuid())
  companyId      String?              @map("company_id")
  company        Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  roleId         String?              @map("role_id")
  roleProfile    Role?                @relation(fields: [roleId], references: [id], onDelete: SetNull)
  nome           String
  email          String               @unique
  passwordHash   String?              @map("password_hash")
  role           UserRole             @default(VIEWER)
  status         UserStatus           @default(ACTIVE)
  lastLoginAt    DateTime?            @map("last_login_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  refreshTokens  AuthRefreshToken[]
  passwordResets PasswordResetToken[]
  auditLogs      AuditLog[]

  @@index([companyId, status])
  @@index([roleId, status])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuthRefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt])
  @@map("auth_refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  method     String?
  path       String?
  ipAddress  String?  @map("ip_address")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, resource, createdAt])
  @@map("audit_logs")
}
