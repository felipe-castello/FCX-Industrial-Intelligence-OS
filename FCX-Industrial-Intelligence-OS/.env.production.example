# FCX Industrial Intelligence OS - Production
# Copie para .env.production e troque todos os valores CHANGE_ME antes do deploy.

TZ=America/Sao_Paulo

NODE_ENV=production
DOMAIN=nexusiotenergy.com.br
APP_DOMAIN=app.nexusiotenergy.com.br
API_DOMAIN=api.nexusiotenergy.com.br
GRAFANA_DOMAIN=grafana.nexusiotenergy.com.br
MQTT_DASHBOARD_DOMAIN=mqtt.nexusiotenergy.com.br
APP_URL=https://app.nexusiotenergy.com.br
API_URL=https://api.nexusiotenergy.com.br
LETSENCRYPT_EMAIL=admin@nexusiotenergy.com.br
SSL_ENABLED=false

POSTGRES_USER=fcx
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_32_CHARS_MIN
POSTGRES_DB=fcx_industrial_os
DATABASE_URL=postgresql://fcx:CHANGE_ME_POSTGRES_32_CHARS_MIN@postgres:5432/fcx_industrial_os

REDIS_PASSWORD=CHANGE_ME_REDIS_32_CHARS_MIN
REDIS_URL=redis://:CHANGE_ME_REDIS_32_CHARS_MIN@redis:6379
REDIS_MAXMEMORY=512mb

MQTT_URL=mqtt://emqx:1883
MQTT_PUBLIC_BIND=0.0.0.0
MQTT_TELEMETRY_TOPIC=fcx/telemetry/+
MQTT_SIMULATOR_TOPIC_PREFIX=fcx/telemetry
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=CHANGE_ME_EMQX_32_CHARS_MIN
EMQX_NODE_COOKIE=CHANGE_ME_EMQX_CLUSTER_COOKIE_32_CHARS_MIN

JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET_64_CHARS_MIN
API_KEY=CHANGE_ME_RANDOM_API_KEY_64_CHARS_MIN
SECURITY_AUTH_ENABLED=true
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
API_PORT=3000
PUBLIC_API_URL=https://api.nexusiotenergy.com.br
CORS_ORIGIN=https://app.nexusiotenergy.com.br

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_32_CHARS_MIN
GRAFANA_ROOT_URL=https://grafana.nexusiotenergy.com.br
PROMETHEUS_RETENTION=15d

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO=

RUN_SEED=false

MODBUS_HOST=127.0.0.1
MODBUS_PORT=502
MODBUS_UNIT_ID=1

CAREL_BOSS_URL=http://localhost:8081
CAREL_BOSS_TOKEN=CHANGE_ME
SITRAD_PRO_URL=http://localhost:8082
SITRAD_PRO_TOKEN=CHANGE_ME
THINGSBOARD_URL=http://localhost:8080
THINGSBOARD_TOKEN=CHANGE_ME
FCX_GATEWAY_URL=http://localhost:8090

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GITHUB_TOKEN=
NANGO_SECRET_KEY=
NANGO_HOST=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
FCX_ENV=production
FCX_MODE=modular
FINNHUB_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TRADING_AGENTS_MODE=research
FCX_RISK_MODE=conservative
ENABLE_AGENT_SKILLS=false
ENABLE_LIBRECHAT=false
ENABLE_LANGCHAIN=true
ENABLE_NANGO=false
ENABLE_QUANTDINGER=false
ENABLE_UNDERSTAND_ANYTHING=false

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
